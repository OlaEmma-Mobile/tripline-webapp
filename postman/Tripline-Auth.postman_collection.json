    {
      "name": "Payments",
      "description": "Token purchase and payment initiation endpoints.",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create pending token purchase and initialize Paystack transaction.",
            "url": "{{baseUrl}}/api/payments/initiate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountNgn\": 1000\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Paystack",
      "description": "Paystack webhook endpoint for payment verification and wallet crediting.",
      "item": [
        {
          "name": "Paystack Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Receive Paystack events (charge.success etc). Public endpoint, signature-verified server-side.",
            "url": "{{baseUrl}}/api/paystack/webhook",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"reference\": \"{{paystackReference}}\"\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "description": "Rider booking lifecycle endpoints including lock, confirm, cancel, and driver boarding updates.",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create booking and deduct tokens atomically.",
            "url": "{{baseUrl}}/api/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideInstanceId\": \"{{rideInstanceId}}\",\n  \"pickupPointId\": \"{{pickupPointId}}\",\n  \"seatCount\": 1\n}"
            }
          }
        },
        {
          "name": "Lock Seat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create pending seat lock with TTL via DB RPC.",
            "url": "{{baseUrl}}/api/bookings/lock",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideInstanceId\": \"{{rideInstanceId}}\",\n  \"seatCount\": 1\n}"
            }
          }
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "Confirm locked booking.",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/confirm"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "Cancel booking by rider.",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "List current authenticated rider bookings.",
            "url": "{{baseUrl}}/api/bookings/me"
          }
        },
        {
          "name": "Driver Board/No-Show",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Driver marks booking as BOARDED or NO_SHOW.",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/board",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"BOARDED\"\n}"
            }
          }
        }
      ]
    },
