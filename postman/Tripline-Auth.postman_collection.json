  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (!data.hasError && data.data && data.data.verifyToken) {",
                  "  pm.environment.set('verifyToken', data.data.verifyToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Tola\",\n  \"lastName\": \"Okoro\",\n  \"email\": \"tola@example.com\",\n  \"phone\": \"+2348010000000\",\n  \"password\": \"Password123\",\n  \"role\": \"rider\"\n}"
            }
          }
        },
        {
          "name": "Resend OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (!data.hasError && data.data && data.data.verifyToken) {",
