  "item": [
    {
      "name": "Auth",
      "description": "Public authentication endpoints for rider/driver login, registration, OTP verification, password reset, and token refresh.\nAll responses use: { hasError, data, message, description, errors }.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create rider/driver account and trigger OTP verification.",
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Tola\",\n  \"lastName\": \"Okoro\",\n  \"email\": \"tola@example.com\",\n  \"phone\": \"+2348010000000\",\n  \"password\": \"Password123\",\n  \"role\": \"rider\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Login and receive access/refresh tokens.",
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tola@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Verify OTP for email verification or reset flow.",
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verifyToken\": \"{{verifyToken}}\",\n  \"otp\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Resend OTP using existing verify token.",
            "url": "{{baseUrl}}/api/auth/resend-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verifyToken\": \"{{verifyToken}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Start reset flow and receive verify token.",
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tola@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Reset password after OTP verification.",
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"NewPassword123\",\n  \"verifyToken\": \"{{verifyToken}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Rotate refresh token and issue new access token.",
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "description": "Admin/sub_admin authentication endpoints. Use these tokens for /api/admin/* endpoints.",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Login admin/sub_admin and receive admin tokens.",
            "url": "{{baseUrl}}/api/admin/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Admin Refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Refresh admin session tokens.",
            "url": "{{baseUrl}}/api/admin/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Admin Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create admin/sub_admin account (admin only).",
            "url": "{{baseUrl}}/api/admin/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"newadmin@example.com\",\n  \"phone\": \"+2348010000001\",\n  \"password\": \"Password123\",\n  \"role\": \"sub_admin\",\n  \"status\": \"active\"\n}"
            }
          }
        }
      ]
    },
