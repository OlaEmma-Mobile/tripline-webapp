              "mode": "raw",
              "raw": "{\n  \"name\": \"Lekki - VI\",\n  \"fromName\": \"Lekki Phase 1\",\n  \"fromLatitude\": 6.44,\n  \"fromLongitude\": 3.52,\n  \"toName\": \"Victoria Island\",\n  \"toLatitude\": 6.43,\n  \"toLongitude\": 3.42,\n  \"baseTokenCost\": 5,\n  \"status\": \"active\"\n}"
            }
          }
        },
