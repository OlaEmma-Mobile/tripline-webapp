    {
      "name": "Admin Ride Instances",
      "description": "Admin ride scheduling, status operations, manifests, realtime snapshot, and CSV export.",
      "item": [
        {
          "name": "List Ride Instances",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "List ride instances with availability and enrichments.",
            "url": "{{baseUrl}}/api/admin/ride-instances?page={{page}}&limit={{limit}}&routeId={{routeId}}&rideDate={{rideDate}}&status={{status}}"
          }
        },
        {
          "name": "Create Ride Instance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create single departure ride instance.",
            "url": "{{baseUrl}}/api/admin/ride-instances",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routeId\": \"{{routeId}}\",\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"driverId\": \"{{driverId}}\",\n  \"rideDate\": \"2026-03-01\",\n  \"departureTime\": \"06:30\"\n}"
            }
          }
        },
        {
          "name": "Bulk Create Ride Instances",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
