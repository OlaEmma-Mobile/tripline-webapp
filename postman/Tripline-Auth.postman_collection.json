            "url": "{{baseUrl}}/api/paystack/webhook",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"reference\": \"{{paystackReference}}\"\n  }\n}"
            }
          }
        }
      ]
    },
