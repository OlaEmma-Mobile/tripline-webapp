    {
      "name": "Admin Routes",
      "description": "Admin fixed-route management: CRUD, search, pickup points, and reorder.",
      "item": [
        {
          "name": "List Routes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "description": "Paginated route list.",
            "url": "{{baseUrl}}/api/admin/routes?page={{page}}&limit={{limit}}&status={{status}}&companyId={{companyId}}"
          }
        },
        {
          "name": "Create Route",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Create fixed route with from/to coordinates and pricing.",
